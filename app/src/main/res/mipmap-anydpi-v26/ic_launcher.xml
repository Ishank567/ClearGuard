<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 
      For the new official ShieldDNS logo (the image provided):
      - Best practice: Put high-res shield-only PNGs in mipmap-mdpi, mipmap-hdpi, ... mipmap-xxxhdpi
      - Then change foreground to e.g. @mipmap/shield_dns_foreground (or keep vector but update it)
      - The full logo (with "ShieldDNS" text) is perfect for splash, onboarding, and headers.
    -->
    <background android:drawable="@color/clear_bg" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
